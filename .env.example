# Base URL of the backend API. Requests in the app use paths relative to this.
#   - Local dev : http://localhost:5500/api
#   - Production : /api  (same origin), or a full https URL if hosted elsewhere.
REACT_APP_API_URL=http://localhost:5500/api

# ---- Supabase (authentication) ----
# From your Supabase project: Dashboard → Settings → API Keys.
# Use the PUBLISHABLE key (sb_publishable_...); it replaces the legacy "anon"
# key and is safe to expose in the client — Row Level Security protects the
# data. NEVER put the secret (sb_secret_...) key here.
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
