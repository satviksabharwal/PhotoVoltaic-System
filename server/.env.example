# ---- Core ----
# Port the API listens on. Hosting providers usually inject this automatically.
PORT=5500

# Comma-separated list of allowed CORS origins (e.g. "https://app.example.com").
# Leave unset to allow all origins (convenient for local dev).
# CORS_ORIGIN=

# ---- Supabase (authentication + database) ----
# From your Supabase project: Dashboard → Settings → API Keys.
# Use the SECRET key (sb_secret_...); it replaces the legacy "service_role"
# key and bypasses Row Level Security — server only, keep it out of the client.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# (Weather data needs no key: Open-Meteo + PVGIS are free, keyless APIs.)
